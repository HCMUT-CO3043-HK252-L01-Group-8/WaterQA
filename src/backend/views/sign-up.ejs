<% if (error > 0) { %>
<p style="color: red; font-weight: bold; display: block">
    <% if (error==1) {%> Password confirmation does not match <% } %>
    <% if (error==2) {%> Account already existed. Please login <% } %>
    <% if (error==3) {%> Unexpected error! <% } %>
</p>
<%}%>

Already have an account? <a href="/auth/login">Login</a>