<h1>Login</h1>
<form method="POST" action="/auth/login">
    <input name="id" placeholder="User ID" required /><br />
    <input
        type="password"
        name="password"
        placeholder="Password"
        required
    /><br />
    <button type="submit">Login</button>
</form>

<%if (err > 0) {%>
<p style="color: red; font-weight: bold">Wrong credentials! Please try again.</p>
<%}%>


<p>Doesn't have an account? <a href="/accounts/signup">Sign up</a></p>
