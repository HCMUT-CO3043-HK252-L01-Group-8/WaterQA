<h1>Change password</h1>
<form method="POST" action="/accounts/change-password">
    <input
        type="password"
        name="currentPass"
        placeholder="Current password"
        required
    /><br />
    <input
        type="password"
        name="newPass"
        placeholder="New password"
        required
    /><br />
    <input
        type="password"
        name="confirmPass"
        placeholder="Confirm password"
        required
    /><br />
    <button type="submit">Change password</button>
</form>

<%if (err > 0) {%>
<p style="color: red; font-weight: bold">
    <%if (err==1){%>Unexpected error: user not found!<%}%>
    <%if (err==2){%>Current password is wrong<%}%>
    <%if (err==3){%>Password confirmation does not match<%}%>
</p>
<%}%>
