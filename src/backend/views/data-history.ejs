<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Data History</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
        }
        h1 {
            margin-bottom: 20px;
        }
        table {
            border-collapse: collapse;
            width: 100%;
        }
        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }
        th {
            background-color: #f4f4f4;
        }
        tr:nth-child(even) {
            background-color: #fafafa;
        }
    </style>
</head>
<body>

    <h1>Data History</h1>

    <% if (data && data.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <% Object.keys(data[0]).forEach(function(key) { %>
                        <th><%= key %></th>
                    <% }); %>
                </tr>
            </thead>
            <tbody>
                <% data.forEach(function(item) { %>
                    <tr>
                        <% Object.values(item).forEach(function(value) { %>
                            <td><%= value %></td>
                        <% }); %>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No data available.</p>
    <% } %>

<div style="padding-top: 20px;">
    <h2>Export to CSV file</h2>
    <form action="/data/export" method="GET" style="border: 2px solid black; padding: 10px;">
        
        <!-- Radio buttons -->
        <label>
            <input type="radio" name="mode" value="all" checked onclick="toggleLimit()">
            All
        </label>

        <label style="margin-left: 10px;">
            <input type="radio" name="mode" value="top" onclick="toggleLimit()">
            Top
        </label><br/>

        <!-- Limit input -->
        <input 
            type="number" 
            id="limitInput" 
            name="limitInput" 
            placeholder="Enter number of rows"
            min="1"
            style="margin-left: 10px; width: 150px;"
            disabled
        ><br/>

        <!-- Hidden actual limit param -->
        <input type="hidden" name="limit" id="limitHidden" value="-1"><br/>

        <!-- Submit -->
        <button type="submit" style="margin-left: 15px;">
            Export CSV
        </button>
    </form>

    <script>
    function toggleLimit() {
        const isAll = document.querySelector('input[name="mode"]:checked').value === 'all';
        const input = document.getElementById('limitInput');
        const hidden = document.getElementById('limitHidden');

        if (isAll) {
            input.disabled = true;
            hidden.value = -1;
        } else {
            input.disabled = false;
            hidden.value = input.value || '';
        }
    }

    // Update hidden value when typing
    document.getElementById('limitInput').addEventListener('input', function () {
        document.getElementById('limitHidden').value = this.value;
    });
    </script>
</div>
    

</body>
</html>